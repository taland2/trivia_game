rules_version = '2';

// Default-deny baseline (doc 09 rules policy).
// Every allowed read/write is added explicitly, per collection, with tests in the
// rules matrix (doc 12 §1). Integrity writes never appear here — they go through
// Cloud Functions only (doc 06 §4).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
