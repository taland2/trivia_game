rules_version = '2';

// Default-deny baseline (doc 09 rules policy).
// Every allowed read/write is added explicitly, per collection, with tests in the
// rules matrix (doc 12 §1). Integrity writes never appear here — they go through
// Cloud Functions only (doc 06 §4). No `allow write` rule exists anywhere below:
// matches, rounds, recaps, matchList, servings and questions are all
// function-written, so clients get read access only where it is safe.
service cloud.firestore {
  match /databases/{database}/documents {

    function isParticipant(players) {
      return request.auth != null && request.auth.uid in players;
    }

    // Friendship edge between two uids (doc 08 §2). pairId is the sorted
    // "{a}_{b}"; rules can't sort strings, so check both concatenations (only the
    // canonical one exists). Written by functions only — Phase 8 social graph.
    function isFriend(a, b) {
      return request.auth != null && (
        exists(/databases/$(database)/documents/friendships/$(a + '_' + b)) ||
        exists(/databases/$(database)/documents/friendships/$(b + '_' + a))
      );
    }

    // Match state visible to its two players. Carries no unanswered-answer data
    // (doc 08 §2), so live exposure is safe.
    match /matches/{matchId} {
      allow read: if isParticipant(resource.data.players);

      // Per-round live state (locked question refs + both players' in-progress
      // answers) is FUNCTION-ONLY — exposing it would leak the opponent's answers
      // before the reveal and the correct-answer refs (guardrail #2). Deny.
      match /rounds/{roundIx} {
        allow read, write: if false;
      }

      // Reveal projection — written by the resolver only once both players finish
      // (doc 08 §2). Readable by either participant.
      match /recaps/{roundIx} {
        allow read: if isParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data.players
        );
      }

      // Emotes (GDD §10.2) — participant-readable banter. Writes are FUNCTION-ONLY
      // (v1_sendEmote validates the set + enforces the per-match cap, guardrail #1);
      // a client-direct write would bypass both, so deny it.
      match /emotes/{emoteId} {
        allow read: if isParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data.players
        );
      }
    }

    // Player profile (doc 08 §2). Readable by the owner AND the owner's friends
    // (Phase 8a widen — the friends list / picker render friend name/avatar/level).
    // Non-friend profiles never reach a client via a listener; username search
    // returns its PUBLIC subset through the v1_searchUsername callable instead.
    // Clients may write ONLY preference fields (guardrail #1 whitelist); integrity
    // fields (xp, level, username, stats, streak, blocked) are function-written and
    // must never be touched by a client. `create` bounds the initial key set; every
    // later `update` may only change whitelisted keys (diff), so function-written
    // fields added afterwards stay locked even though they exist on the doc.
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isFriend(request.auth.uid, uid));

      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(
          ['language', 'isGuest', 'createdAt', 'displayName', 'avatarId',
           'fcmTokens', 'searchable']
        );

      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['language', 'displayName', 'avatarId', 'fcmTokens', 'searchable']
        );
    }

    // Home-screen match cards — owner-readable projection.
    match /users/{uid}/matchList/{matchId} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // Daily play record (doc 08 Daily) — id is "{uid}_{dayId}". Owner-readable so
    // Home can show today's played/score state + streak. Function-written only
    // (v1_submitDailyAnswer); no client write. The curated `dailySets/*` stay
    // denied by the catch-all (GDD §5 — clients never see the set pre-play).
    match /dailyPlays/{playId} {
      allow read: if request.auth != null
        && playId.split('_')[0] == request.auth.uid;
    }

    // Weekly friends leaderboard projection (GDD §7, doc 08 §2). The board already
    // contains the viewer's friends' rows, so it is OWNER-readable only. Maintained
    // by the resolution fan-out (functions) — no client write.
    match /weekly/{weekId}/boards/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // Daily friends-today board (doc 07 §2.4 / doc 08 §2). The owner always reads
    // their own; a friend may read it ONLY after they have finished today's daily
    // (GDD §5 anti-spoiler — no anchoring on others' scores before you play). The
    // exists() guard precedes the get() so a never-played reader doesn't error.
    match /daily/{dayId}/friendScores/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid || (
          isFriend(request.auth.uid, uid)
          && exists(/databases/$(database)/documents/dailyPlays/$(request.auth.uid + '_' + dayId))
          && get(/databases/$(database)/documents/dailyPlays/$(request.auth.uid + '_' + dayId)).data.finishedAt != null
        )
      );
    }

    // Social graph (Phase 8a, doc 08 §2). All function-written (guardrail #1) — no
    // `allow write` anywhere; clients only READ the slices that concern them.

    // A friendship edge — readable by either member (the weekly board + friends
    // list need it). `uids` is the sorted pair.
    match /friendships/{pairId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.uids;
    }

    // Friend requests — readable by the sender or the recipient only.
    match /friendRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // Invite codes — readable by the issuer only (redeemers go through the
    // v1_redeemInviteCode callable, so codes can't be enumerated by readers).
    match /invites/{code} {
      allow read: if request.auth != null && resource.data.issuerUid == request.auth.uid;
    }

    // Everything else (questions bank, servingsPrivate, idempotency, weekly
    // scores, dailySets, usernames registry, …) stays denied by this catch-all.
    // `usernames/*` is intentionally here — search is callable-only, so the client
    // never reads the registry directly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
