rules_version = '2';

// Default-deny baseline (doc 09 rules policy).
// Every allowed read/write is added explicitly, per collection, with tests in the
// rules matrix (doc 12 §1). Integrity writes never appear here — they go through
// Cloud Functions only (doc 06 §4). No `allow write` rule exists anywhere below:
// matches, rounds, recaps, matchList, servings and questions are all
// function-written, so clients get read access only where it is safe.
service cloud.firestore {
  match /databases/{database}/documents {

    function isParticipant(players) {
      return request.auth != null && request.auth.uid in players;
    }

    // Match state visible to its two players. Carries no unanswered-answer data
    // (doc 08 §2), so live exposure is safe.
    match /matches/{matchId} {
      allow read: if isParticipant(resource.data.players);

      // Per-round live state (locked question refs + both players' in-progress
      // answers) is FUNCTION-ONLY — exposing it would leak the opponent's answers
      // before the reveal and the correct-answer refs (guardrail #2). Deny.
      match /rounds/{roundIx} {
        allow read, write: if false;
      }

      // Reveal projection — written by the resolver only once both players finish
      // (doc 08 §2). Readable by either participant.
      match /recaps/{roundIx} {
        allow read: if isParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data.players
        );
      }

      // Emotes (GDD §10.2) — participant-readable banter. Writes are FUNCTION-ONLY
      // (v1_sendEmote validates the set + enforces the per-match cap, guardrail #1);
      // a client-direct write would bypass both, so deny it.
      match /emotes/{emoteId} {
        allow read: if isParticipant(
          get(/databases/$(database)/documents/matches/$(matchId)).data.players
        );
      }
    }

    // Player profile (doc 08 §2). Owner-readable (Phase 8 widens reads to friends).
    // Clients may write ONLY preference fields (guardrail #1 whitelist); integrity
    // fields (xp, level, username, stats, streak, blocked) are function-written and
    // must never be touched by a client. `create` bounds the initial key set; every
    // later `update` may only change whitelisted keys (diff), so function-written
    // fields added afterwards stay locked even though they exist on the doc.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(
          ['language', 'isGuest', 'createdAt', 'displayName', 'avatarId',
           'fcmTokens', 'searchable']
        );

      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['language', 'displayName', 'avatarId', 'fcmTokens', 'searchable']
        );
    }

    // Home-screen match cards — owner-readable projection.
    match /users/{uid}/matchList/{matchId} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // Daily play record (doc 08 Daily) — id is "{uid}_{dayId}". Owner-readable so
    // Home can show today's played/score state + streak. Function-written only
    // (v1_submitDailyAnswer); no client write. The curated `dailySets/*` stay
    // denied by the catch-all (GDD §5 — clients never see the set pre-play). The
    // post-play `daily/{dayId}/friendScores/*` projection lands in Phase 7b.
    match /dailyPlays/{playId} {
      allow read: if request.auth != null
        && playId.split('_')[0] == request.auth.uid;
    }

    // Everything else (questions bank, servingsPrivate, idempotency, …) stays
    // denied by this catch-all.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
